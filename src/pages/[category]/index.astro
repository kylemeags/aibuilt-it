---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { categories, getCategoryBySlug } from '../../data/categories';

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

interface Props {
  category: any;
}

const { category } = Astro.props;
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter((a) => (a.data.category || 'ai-news') === category.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title={`${category.name} — aibuilt.it`}
  description={`AI ${category.description.toLowerCase()}. Real implementations, case studies, and tools.`}
>
  <div class="container py-16 md:py-24">
    <!-- Category header -->
    <div class="mb-12">
      <p class="micro-label mb-3">Category</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        {category.name}
      </h1>
      <p class="mt-3 text-lg text-slate-400 max-w-2xl">
        {category.description}
      </p>
    </div>

    <!-- Articles grid -->
    {articles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article) => (
          <ArticleCard article={{
            title: article.data.title,
            excerpt: article.data.excerpt,
            date: article.data.date,
            author: article.data.author || 'aibuilt.it',
            category: article.data.category || 'ai-news',
            contentType: article.data.contentType || 'news',
            heroImage: article.data.heroImage,
            slug: article.slug,
          }} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-slate-500 text-lg">No articles in this category yet.</p>
        <a href="/" class="mt-4 inline-block text-indigo-400 hover:text-indigo-300 text-sm font-medium transition-colors">
          ← Back to home
        </a>
      </div>
    )}
  </div>
</BaseLayout>

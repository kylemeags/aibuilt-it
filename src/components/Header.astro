---
import { categories } from '../data/categories';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/[0.06]"
  style="background: rgba(10,10,10,0.8); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
>
  <div class="w-full max-w-container mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <svg class="w-5 h-5 text-indigo-400 group-hover:text-indigo-300 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
      </svg>
      <span class="font-display font-bold text-lg text-white tracking-tight">
        aibuilt<span class="text-indigo-400">.it</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      <!-- Categories Dropdown -->
      <div class="relative" id="cat-dropdown">
        <button
          id="cat-toggle"
          class="flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors"
        >
          Categories
          <svg class="w-3.5 h-3.5 transition-transform" id="cat-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div
          id="cat-menu"
          class="absolute top-full mt-2 left-0 w-64 rounded-xl border border-white/[0.06] p-2 hidden"
          style="background: rgba(20,20,20,0.95); backdrop-filter: blur(20px);"
        >
          {categories.map((cat) => (
            <a
              href={`/${cat.slug}/`}
              class="flex items-center justify-between px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-white/[0.04] transition-colors"
            >
              <span class="flex items-center gap-2">
                <span class={`w-2 h-2 rounded-full ${cat.badgeColor.replace('text-', 'bg-')}`} />
                {cat.name}
              </span>
            </a>
          ))}
        </div>
      </div>

      <a href="/#featured" class="text-sm text-slate-400 hover:text-white transition-colors">Featured</a>
      <a href="/#latest" class="text-sm text-slate-400 hover:text-white transition-colors">Latest</a>
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden md:flex items-center">
      <a
        href="#newsletter"
        class="px-4 py-2 rounded-lg bg-indigo-500 hover:bg-indigo-400 text-white text-sm font-medium transition-colors"
      >
        Subscribe
      </a>
    </div>

    <!-- Mobile Toggle -->
    <button
      id="mobile-toggle"
      class="md:hidden text-slate-400 hover:text-white transition-colors"
      aria-label="Toggle menu"
    >
      <svg id="menu-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg id="menu-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden border-t border-white/[0.06] px-4 py-4 space-y-3 hidden"
    style="background: rgba(10,10,10,0.95);"
  >
    <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-zinc-600 mb-2">Categories</p>
    {categories.map((cat) => (
      <a
        href={`/${cat.slug}/`}
        class="flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors py-1"
      >
        <span class={`w-2 h-2 rounded-full ${cat.badgeColor.replace('text-', 'bg-')}`} />
        {cat.name}
      </a>
    ))}
    <div class="pt-3 border-t border-white/[0.06]">
      <a
        href="#newsletter"
        class="block text-center px-4 py-2 rounded-lg bg-indigo-500 hover:bg-indigo-400 text-white text-sm font-medium transition-colors"
      >
        Subscribe
      </a>
    </div>
  </div>
</header>

<script>
  // Category dropdown toggle
  const catToggle = document.getElementById('cat-toggle');
  const catMenu = document.getElementById('cat-menu');
  const catChevron = document.getElementById('cat-chevron');

  catToggle?.addEventListener('click', () => {
    catMenu?.classList.toggle('hidden');
    catChevron?.classList.toggle('rotate-180');
  });

  document.addEventListener('click', (e) => {
    const dropdown = document.getElementById('cat-dropdown');
    if (dropdown && !dropdown.contains(e.target as Node)) {
      catMenu?.classList.add('hidden');
      catChevron?.classList.remove('rotate-180');
    }
  });

  // Mobile menu toggle
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpen = document.getElementById('menu-open');
  const menuClose = document.getElementById('menu-close');

  mobileToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuOpen?.classList.toggle('hidden');
    menuClose?.classList.toggle('hidden');
  });
</script>

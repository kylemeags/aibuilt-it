---
// Footer — dark footer with newsletter, links, and branding
---

<footer id="newsletter" class="border-t border-white/[0.06]" style="background: #070707;">
  <div class="w-full max-w-container mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
    <!-- Newsletter Section -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-zinc-600 mb-4">Stay in the loop</p>
      <h3 class="font-display text-2xl md:text-3xl font-bold text-white mb-3">
        Get the best AI implementations in your inbox
      </h3>
      <p class="text-slate-500 text-sm md:text-base mb-6">
        Weekly curated case studies, tool reviews, and actionable guides. No fluff, no spam.
      </p>
      <form class="flex gap-2 max-w-md mx-auto" action="#" method="post">
        <input
          type="email"
          placeholder="you@company.com"
          class="flex-1 px-4 py-2.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-white text-sm placeholder:text-zinc-600 focus:outline-none focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/30 transition-all"
        />
        <button
          type="submit"
          class="px-5 py-2.5 rounded-lg bg-indigo-500 hover:bg-indigo-400 text-white text-sm font-medium transition-colors flex items-center gap-1.5 shrink-0"
        >
          Subscribe
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </button>
      </form>
    </div>

    <!-- Links Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <div>
        <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-zinc-600 mb-4">Platform</p>
        <ul class="space-y-2.5">
          <li><a href="/#featured" class="text-sm text-slate-500 hover:text-white transition-colors">Case Studies</a></li>
          <li><a href="/#latest" class="text-sm text-slate-500 hover:text-white transition-colors">Tool Reviews</a></li>
          <li><a href="/#latest" class="text-sm text-slate-500 hover:text-white transition-colors">How-To Guides</a></li>
          <li><a href="/ai-news/" class="text-sm text-slate-500 hover:text-white transition-colors">AI News</a></li>
        </ul>
      </div>
      <div>
        <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-zinc-600 mb-4">Categories</p>
        <ul class="space-y-2.5">
          <li><a href="/marketing-seo/" class="text-sm text-slate-500 hover:text-white transition-colors">Marketing & SEO</a></li>
          <li><a href="/video-creative/" class="text-sm text-slate-500 hover:text-white transition-colors">Video & Creative</a></li>
          <li><a href="/automation/" class="text-sm text-slate-500 hover:text-white transition-colors">Automation</a></li>
          <li><a href="/sales-crm/" class="text-sm text-slate-500 hover:text-white transition-colors">Sales & CRM</a></li>
        </ul>
      </div>
      <div>
        <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-zinc-600 mb-4">Company</p>
        <ul class="space-y-2.5">
          <li><a href="/about" class="text-sm text-slate-500 hover:text-white transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-slate-500 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-zinc-600 mb-4">Connect</p>
        <ul class="space-y-2.5">
          <li><a href="#" class="text-sm text-slate-500 hover:text-white transition-colors">Twitter / X</a></li>
          <li><a href="#" class="text-sm text-slate-500 hover:text-white transition-colors">LinkedIn</a></li>
          <li><a href="/rss.xml" class="text-sm text-slate-500 hover:text-white transition-colors">RSS Feed</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/[0.06] flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
        </svg>
        <span class="font-display font-bold text-sm text-white">
          aibuilt<span class="text-indigo-400">.it</span>
        </span>
      </div>
      <p class="text-xs text-zinc-600">
        &copy; {new Date().getFullYear()} aibuilt.it. All rights reserved.
      </p>
    </div>
  </div>
</footer>

---
import { getCategoryBySlug } from '../data/categories';

interface Props {
  categorySlug: string;
  className?: string;
}

const { categorySlug, className = '' } = Astro.props;
const category = getCategoryBySlug(categorySlug);
---

{category && (
  <span
    class:list={[
      'inline-flex items-center px-2.5 py-0.5 rounded-full text-[0.6875rem] font-medium',
      category.badgeBg,
      category.badgeColor,
      className,
    ]}
  >
    {category.name}
  </span>
)}

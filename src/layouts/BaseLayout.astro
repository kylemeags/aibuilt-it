---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  articleDate?: string;
}

const {
  title,
  description = 'AI-powered articles on tech, web development, and beyond.',
  ogImage = '/og-default.png',
  articleDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://aibuilt.it');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content={articleDate ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="aibuilt.it" />
    <meta property="og:image" content={new URL(ogImage, Astro.site || 'https://aibuilt.it').href} />
    {articleDate && <meta property="article:published_time" content={articleDate} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site || 'https://aibuilt.it').href} />

    <!-- Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <meta name="theme-color" content="#ffffff" />
  </head>
  <body class="bg-white text-gray-900 antialiased min-h-screen flex flex-col">
    <header class="border-b border-gray-200">
      <nav class="mx-auto max-w-3xl px-4 py-6 sm:px-6">
        <a href="/" class="text-xl font-bold text-gray-900 hover:text-blue-600 transition-colors">
          aibuilt.it
        </a>
      </nav>
    </header>

    <main class="mx-auto max-w-3xl w-full px-4 py-10 sm:px-6 flex-1">
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-auto">
      <div class="mx-auto max-w-3xl px-4 py-8 sm:px-6 text-center text-sm text-gray-500">
        <p>&copy; {new Date().getFullYear()} aibuilt.it</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  @layer base {
    html {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }
    body {
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.7;
    }
    h1, h2, h3 { line-height: 1.3; }
  }

  /* Prose styling for article content */
  .prose h1 { @apply text-3xl sm:text-4xl font-bold mb-4 mt-8; }
  .prose h2 { @apply text-2xl font-bold mb-3 mt-8; }
  .prose h3 { @apply text-xl font-semibold mb-2 mt-6; }
  .prose p { @apply mb-5 text-base leading-relaxed; }
  .prose ul { @apply list-disc pl-6 mb-5 space-y-1; }
  .prose ol { @apply list-decimal pl-6 mb-5 space-y-1; }
  .prose li { @apply text-base; }
  .prose blockquote { @apply border-l-4 border-gray-300 pl-4 italic text-gray-600 my-6; }
  .prose pre { @apply bg-gray-50 rounded-lg p-4 overflow-x-auto mb-5 text-sm; }
  .prose code { @apply bg-gray-100 px-1.5 py-0.5 rounded text-sm font-mono; }
  .prose pre code { @apply bg-transparent p-0; }
  .prose a { @apply text-blue-600 hover:underline; }
  .prose img { @apply rounded-lg my-6 max-w-full h-auto; }
  .prose hr { @apply my-8 border-gray-200; }
  .prose strong { @apply font-semibold; }
</style>

---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  articleDate?: string;
  /** If true, renders a white content area for articles. Default is dark (homepage). */
  lightContent?: boolean;
  /** Optional JSON-LD structured data */
  jsonLd?: Record<string, any>;
}

const {
  title,
  description = 'Real AI implementations. Real results. Discover how businesses use AI with case studies, tool reviews, and actionable guides.',
  ogImage = '/og-default.png',
  articleDate,
  lightContent = false,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://aibuilt.it');
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content={articleDate ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="aibuilt.it" />
    <meta property="og:image" content={new URL(ogImage, Astro.site || 'https://aibuilt.it').href} />
    {articleDate && <meta property="article:published_time" content={articleDate} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site || 'https://aibuilt.it').href} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <meta name="theme-color" content="#0a0a0a" />

    <!-- JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="bg-surface text-white antialiased min-h-screen flex flex-col font-sans" style="background: #0a0a0a;">
    <Header />

    <!-- Spacer for fixed header -->
    <div class="h-16"></div>

    {lightContent ? (
      <main class="flex-1">
        <slot />
      </main>
    ) : (
      <main class="flex-1">
        <slot />
      </main>
    )}

    <Footer />

    <!-- Scroll reveal animation -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll('.reveal-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  @layer base {
    html {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
      scroll-behavior: smooth;
    }
    body {
      line-height: 1.7;
    }
    h1, h2, h3, h4 {
      line-height: 1.15;
    }
  }

  @layer components {
    /* Container utility */
    .container {
      width: 100%;
      margin-left: auto;
      margin-right: auto;
      padding-left: 1rem;
      padding-right: 1rem;
    }
    @media (min-width: 640px) {
      .container { padding-left: 1.5rem; padding-right: 1.5rem; }
    }
    @media (min-width: 1024px) {
      .container { padding-left: 2rem; padding-right: 2rem; max-width: 1280px; }
    }

    /* Glass card effect */
    .glass-card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.06);
      transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    .glass-card:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(99, 102, 241, 0.3);
      transform: translateY(-4px);
      box-shadow: 0 0 30px rgba(99, 102, 241, 0.08);
    }

    /* Micro label */
    .micro-label {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #52525b;
    }

    /* Gradient mesh blobs */
    .gradient-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.06;
      pointer-events: none;
    }

    /* Scroll reveal */
    .reveal-on-scroll {
      opacity: 0;
      transform: translateY(1.5rem);
      transition: opacity 700ms ease-out, transform 700ms ease-out;
    }
    .reveal-on-scroll.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* Hide scrollbar for category scroll */
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
  }

  /* Prose styling for article content (white bg context) */
  .prose h1 { @apply text-3xl sm:text-4xl font-bold mb-4 mt-8 text-gray-900; }
  .prose h2 { @apply text-2xl font-bold mb-3 mt-8 text-gray-900; }
  .prose h3 { @apply text-xl font-semibold mb-2 mt-6 text-gray-900; }
  .prose p { @apply mb-5 text-base leading-relaxed text-gray-700; }
  .prose ul { @apply list-disc pl-6 mb-5 space-y-1; }
  .prose ol { @apply list-decimal pl-6 mb-5 space-y-1; }
  .prose li { @apply text-base text-gray-700; }
  .prose blockquote { @apply border-l-4 border-gray-300 pl-4 italic text-gray-600 my-6; }
  .prose pre { @apply bg-gray-50 rounded-lg p-4 overflow-x-auto mb-5 text-sm; }
  .prose code { @apply bg-gray-100 px-1.5 py-0.5 rounded text-sm font-mono; }
  .prose pre code { @apply bg-transparent p-0; }
  .prose a { @apply text-indigo-600 hover:text-indigo-500 hover:underline; }
  .prose img { @apply rounded-lg my-6 max-w-full h-auto; }
  .prose hr { @apply my-8 border-gray-200; }
  .prose strong { @apply font-semibold text-gray-900; }
</style>

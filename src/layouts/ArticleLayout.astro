---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/date';

interface Props {
  title: string;
  date: Date;
  tags: string[];
}

const { title, date, tags } = Astro.props;
---

<BaseLayout title={title}>
  <article class="prose prose-sm max-w-none">
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4 text-gray-900">{title}</h1>
      <div class="flex flex-col sm:flex-row sm:items-center sm:gap-4 text-sm text-gray-600">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        <div class="flex gap-2">
          {tags.map((tag) => (
            <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-xs font-medium">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </header>

    <div class="mt-8 prose prose-sm max-w-none prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline">
      <slot />
    </div>
  </article>

  <nav class="mt-12 pt-8 border-t border-gray-200">
    <a href="/" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to articles
    </a>
  </nav>
</BaseLayout>
